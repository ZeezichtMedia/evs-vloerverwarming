---
---

<section class="relative h-[80vh] min-h-[500px] flex items-center justify-center text-white overflow-hidden">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0">
    <img 
      src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-10_result.webp" 
      alt="Vloerverwarming installatie" 
      class="w-full h-full object-cover"
    />
    <!-- Lighter overlay: bg-black/30 as requested for better photo visibility -->
    <div class="absolute inset-0 bg-black/30"></div>
  </div>

  <!-- Content -->
  <div class="container relative z-10 text-center px-4 max-w-4xl">
    <span class="block text-white font-bold tracking-widest uppercase mb-3 text-sm md:text-base animate-fade-in-up drop-shadow-md">Vakmanschap sinds 2001</span>
    <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight animate-fade-in-up delay-100 drop-shadow-lg text-white">
      Vloerverwarming frezen <br/>
      <span class="text-white">zonder stofoverlast</span>
    </h1>
    <p class="text-base sm:text-lg md:text-xl text-white mb-8 leading-relaxed max-w-xl mx-auto animate-fade-in-up delay-200 font-medium drop-shadow-md">
      Kies voor comfort en kwaliteit. EvS is de specialist in het frezen van vloerverwarming, dichtsmeren en egaliseren in Zeeland en West-Brabant.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center animate-fade-in-up delay-300">
      <a 
        href="/offerte" 
        class="bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-full text-base transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1 border-2 border-transparent"
      >
        Direct offerte aanvragen
      </a>
      <a 
        href="/diensten" 
        class="bg-transparent hover:bg-white/10 text-white border-2 border-white font-bold py-3 px-8 rounded-full text-base transition-all"
      >
        Bekijk onze diensten
      </a>
    </div>
  </div>
</section>

<style>
  .delay-100 { animation-delay: 100ms; }
  .delay-200 { animation-delay: 200ms; }
  .delay-300 { animation-delay: 300ms; }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .animate-fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    opacity: 0;
  }
</style>
