---
const currentYear = new Date().getFullYear();
---

<footer class="bg-white text-gray-900 pt-16 pb-8 border-t border-gray-100">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Brand -->
      <div>
        <a href="/" class="text-2xl font-black text-navy tracking-tight flex items-center gap-2 mb-6">
          <span class="text-3xl text-primary">EvS</span> bv
        </a>
        <p class="text-gray-600 leading-relaxed mb-6">
          Specialist in stofvrij vloerverwarming frezen. Wij staan voor betrouwbaarheid, vakmanschap en een persoonlijke aanpak in Zeeland en West-Brabant.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-navy border-b-2 border-primary inline-block pb-2">Contact</h3>
        <ul class="space-y-4 text-gray-600">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13 21.314l-4.657-4.657a8 8 0 0111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>Zoutelande, Zeeland</span>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href="tel:+31612345678" class="hover:text-primary transition-colors">Bel ons direct</a>
          </li>
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href="mailto:info@evs-vloerverwarming.nl" class="hover:text-primary transition-colors">info@evs-vloerverwarming.nl</a>
          </li>
        </ul>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-navy border-b-2 border-primary inline-block pb-2">Snel naar</h3>
        <ul class="space-y-3 text-gray-600">
          <li><a href="/diensten" class="hover:text-primary transition-colors flex items-center gap-2"><span class="text-primary">›</span> Alle diensten</a></li>
          <li><a href="/vloerverwarming-frezen" class="hover:text-primary transition-colors flex items-center gap-2"><span class="text-primary">›</span> Vloerverwarming frezen</a></li>
          <li><a href="/contact" class="hover:text-primary transition-colors flex items-center gap-2"><span class="text-primary">›</span> Contact opnemen</a></li>
          <li><a href="/offerte" class="hover:text-primary transition-colors flex items-center gap-2"><span class="text-primary">›</span> Offerte aanvragen</a></li>
        </ul>
      </div>
      
      <!-- Certifications / Extra -->
      <div>
        <h3 class="text-xl font-bold mb-6 text-navy border-b-2 border-primary inline-block pb-2">Werkgebied</h3>
        <p class="text-gray-600 mb-4">
          Wij zijn actief in heel Zeeland en West-Brabant. Van Vlissingen tot Breda.
        </p>
      </div>
    </div>
    
    <div class="border-t border-gray-100 pt-8 flex flex-col md:flex-row justify-between items-center text-sm text-gray-500">
      <p>&copy; {currentYear} EvS Vloerverwarming. Alle rechten voorbehouden.</p>
      <div class="mt-4 md:mt-0">
        <a href="/privacy" class="hover:text-primary mr-4 transition-colors">Privacyverklaring</a>
        <a href="/voorwaarden" class="hover:text-primary transition-colors">Algemene Voorwaarden</a>
      </div>
    </div>
  </div>
</footer>
