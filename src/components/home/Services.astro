---
import SectionHeading from '../ui/SectionHeading.astro';
import ServiceCard from '../ServiceCard.astro';

const services = [
  {
    title: 'Vloerverwarming frezen',
    description: 'Stofvrij invrezen van vloerverwarming in zandcement, beton of anhydriet. Snel, vakkundig en zonder overlast.',
    link: '/vloerverwarming-frezen',
    image: '/images/concrete.jpg',
    number: '01 — Frezen',
  },
  {
    title: 'Dichtsmeren & Egaliseren',
    description: 'De sleuven vakkundig dichtsmeren of de gehele vloer egaliseren voor een perfect glad eindresultaat.',
    link: '/dichtsmeren-egaliseren',
    image: '/images/dichtsmeren.jpg',
    number: '02 — Afwerken',
  },
  {
    title: 'Vloeren verwijderen & schuren',
    description: 'Oude lijmresten, coatings of oneffenheden wegschuren. Kaal en klaar voor verdere bewerking.',
    link: '/vloeren-schuren',
    image: '/images/tools.jpg',
    number: '03 — Voorbereiden',
  },
];
---

<section class="relative py-20 lg:py-32 bg-stone-50 overflow-hidden">
  <div class="absolute top-20 -left-40 w-80 h-80 rounded-full bg-primary/5 blur-3xl"></div>
  <div class="absolute bottom-20 -right-40 w-96 h-96 rounded-full bg-primary/5 blur-3xl"></div>

  <div class="container relative">
    <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-14 lg:mb-20">
      <SectionHeading
        eyebrow="Diensten"
        title={`Eén vakman.<br/>Één <span class="text-primary">complete oplossing</span>.`}
        lead="Van de eerste freesbeweging tot de gladde egaline-afwerking — alle stappen door hetzelfde team."
      />
      <a href="/diensten" class="reveal stagger-3 btn-pill btn-outline shrink-0">
        Alle diensten
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {services.map((s, i) => (
        <div class={`reveal stagger-${i + 1}`}>
          <ServiceCard {...s} />
        </div>
      ))}
    </div>
  </div>
</section>
