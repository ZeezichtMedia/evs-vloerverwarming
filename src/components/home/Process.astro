---
import SectionHeading from '../ui/SectionHeading.astro';

const steps = [
  {
    number: '01',
    title: 'Offerte in 8 uur',
    description: 'Vul het stappenplan in. Je ontvangt dezelfde dag nog een complete prijsindicatie op maat.',
    icon: 'M21.21 15.89A10 10 0 1 1 8 2.83 M22 12A10 10 0 0 0 12 2v10z',
  },
  {
    number: '02',
    title: 'Inplannen',
    description: 'Kort overleg over datum, toegang en bijzonderheden. Jij kiest, wij schakelen.',
    icon: 'M8 2v4 M16 2v4 M3 10h18 M21 20V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2z',
  },
  {
    number: '03',
    title: 'Frezen & leggen',
    description: 'Binnen één dag freest EvS de sleuven stofvrij en legt de vloerverwarmingsbuizen vakkundig.',
    icon: 'M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z',
  },
  {
    number: '04',
    title: 'Klaar voor warmte',
    description: 'Na dichtsmeren of egaliseren kan de vloerlegger direct aan de slag. Jij geniet van comfort.',
    icon: 'M4 10h12 M4 14h9 M19 6a7.7 7.7 0 0 0-5.2-2A7.9 7.9 0 0 0 6 12c0 4.4 3.5 8 7.8 8 2 0 3.8-.8 5.2-2',
  },
];
---

<section class="relative py-20 lg:py-32 bg-ink-800 text-white overflow-hidden heat-glow">
  <div class="absolute inset-0 grain"></div>

  <div class="relative container">
    <div class="max-w-3xl mb-16 lg:mb-24">
      <SectionHeading
        eyebrow="Zo werken wij"
        title={`Vier stappen tussen<br/>jou en <span class="text-primary">warmte onder je voeten</span>.`}
        lead="Geen maanden wachten. Geen eindeloze offerte-trajecten. Een strak proces dat gewoon werkt."
        theme="dark"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {steps.map((step, i) => (
        <div class={`reveal stagger-${i + 1} group relative frosted-dark rounded-3xl p-7 lg:p-8 transition-all hover:-translate-y-2 hover:border-primary/40`}>
          <div class="flex items-center justify-between mb-6">
            <span class="font-heading font-black text-primary text-5xl lg:text-6xl leading-none">
              {step.number}
            </span>
            <span class="w-12 h-12 rounded-xl border border-white/20 group-hover:border-primary group-hover:bg-primary/10 grid place-items-center text-white/60 group-hover:text-primary transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={step.icon}/>
              </svg>
            </span>
          </div>
          <h3 class="font-heading font-black text-white text-xl lg:text-2xl mb-3 leading-tight">
            {step.title}
          </h3>
          <p class="text-white/60 text-sm leading-relaxed">
            {step.description}
          </p>

          {i < steps.length - 1 && (
            <div class="hidden lg:flex absolute right-0 top-1/2 translate-x-full -translate-y-1/2 items-center justify-center w-6 h-6 z-10 text-primary/50 pointer-events-none">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
