---
const links = [
  { href: '/diensten', label: 'Alle diensten' },
  { href: '/vloerverwarming-frezen', label: 'Vloerverwarming frezen' },
  { href: '/dichtsmeren-egaliseren', label: 'Dichtsmeren of egaliseren' },
  { href: '/vloeren-schuren', label: 'Vloeren schuren' },
  { href: '/contact', label: 'Contact' },
];
---

<header class="sticky top-0 z-50 bg-primary border-b border-primary-dark shadow-md transition-all duration-300" id="main-header">
  <div class="container flex items-center justify-between h-20">
    <a href="/" class="flex items-center gap-2 group">
      <img 
        src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2021/05/logo-evs-vloerverwarming-wit-e1752674223249.webp" 
        alt="EVS Vloerverwarming" 
        class="h-10 w-auto opacity-100 group-hover:opacity-90 transition-opacity" 
      />
    </a>

    <!-- Desktop Menu -->
    <nav class="hidden lg:flex items-center gap-8">
      <ul class="flex items-center gap-6">
        {links.map(link => (
          <li>
            <a 
              href={link.href} 
              class="text-sm font-bold text-white hover:text-white/80 transition-colors uppercase tracking-wide"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
      <a 
        href="/offerte" 
        class="bg-white hover:bg-gray-100 text-primary font-bold py-3 px-6 rounded-full transition-all hover:shadow-lg transform hover:-translate-y-0.5 text-sm uppercase tracking-wide"
      >
        Offerte aanvragen
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-btn" class="lg:hidden text-white p-2 focus:outline-none" aria-label="Menu">
      <!-- Hamburger Icon -->
      <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <!-- Close Icon (Hidden by default) -->
      <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 hidden transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="absolute top-full left-0 w-full bg-white border-t border-gray-100 shadow-xl hidden flex-col divide-y divide-gray-50 text-navy">
    <nav class="flex flex-col py-2">
      {links.map(link => (
        <a 
          href={link.href} 
          class="font-bold py-4 px-6 hover:bg-gray-50 hover:text-primary transition-colors flex items-center justify-between group"
          onclick="toggleMenu()"
        >
          {link.label}
          <span class="text-primary opacity-0 group-hover:opacity-100 transition-opacity">→</span>
        </a>
      ))}
      <div class="p-4 mt-2">
        <a 
          href="/offerte" 
          class="block bg-primary text-white font-bold py-4 rounded-full text-center shadow-md hover:bg-primary-dark transition-all transform active:scale-95"
          onclick="toggleMenu()"
        >
          Offerte aanvragen
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  function toggleMenu() {
    const isHidden = mobileMenu.classList.contains('hidden');
    
    if (isHidden) {
      mobileMenu.classList.remove('hidden');
      mobileMenu.classList.add('flex');
      // Icon switch
      hamburgerIcon.classList.add('hidden');
      closeIcon.classList.remove('hidden');
    } else {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
      // Icon switch
      hamburgerIcon.classList.remove('hidden');
      closeIcon.classList.add('hidden');
    }
  }

  menuBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleMenu();
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (!mobileMenu.classList.contains('hidden') && !mobileMenu.contains(e.target) && !menuBtn.contains(e.target)) {
      toggleMenu();
    }
  });
</script>
