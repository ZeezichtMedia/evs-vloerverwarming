---
interface Props {
  title: string;
  description: string;
  link: string;
  image: string;
  number?: string;
}

const { title, description, link, image, number } = Astro.props;
---

<a href={link} class="premium-card group block bg-white border border-stone-200 reveal">
  <div class="relative aspect-[4/3] overflow-hidden">
    <img src={image} alt={title} class="card-img-zoom w-full h-full object-cover" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-ink-800/90 via-ink-800/30 to-transparent"></div>
    {number && (
      <span class="absolute top-5 left-5 font-heading font-black text-white/90 text-xs tracking-[0.3em] uppercase">
        {number}
      </span>
    )}
    <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between gap-4">
      <h3 class="font-heading font-black text-white text-2xl leading-tight">
        {title}
      </h3>
      <span class="shrink-0 w-11 h-11 rounded-full bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center text-white group-hover:bg-primary group-hover:border-primary transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
          <path d="M7 17 17 7"/><path d="M7 7h10v10"/>
        </svg>
      </span>
    </div>
  </div>
  <div class="p-6 sm:p-7">
    <p class="text-slate-600 leading-relaxed mb-5">{description}</p>
    <span class="inline-flex items-center gap-2 font-heading font-bold text-sm uppercase tracking-[0.12em] text-primary">
      Meer informatie
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </span>
  </div>
</a>
