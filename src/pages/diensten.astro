---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import ServiceCard from '../components/ServiceCard.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';

const services = [
  {
    title: 'Vloerverwarming frezen',
    description: 'Stofvrij invrezen van vloerverwarming in zandcement, beton of anhydriet. Snel, vakkundig en zonder overlast.',
    link: '/vloerverwarming-frezen',
    image: '/images/hero-2.webp',
    number: '01 — Frezen',
  },
  {
    title: 'Dichtsmeren & Egaliseren',
    description: 'De sleuven vakkundig dichtsmeren of de gehele vloer egaliseren voor een perfect glad eindresultaat.',
    link: '/dichtsmeren-egaliseren',
    image: '/images/dichtsmeren.webp',
    number: '02 — Afwerken',
  },
  {
    title: 'Vloeren verwijderen & schuren',
    description: 'Oude lijmresten, coatings of oneffenheden wegschuren. Kaal en klaar voor verdere bewerking.',
    link: '/vloeren-schuren',
    image: '/images/whatsapp-schuren.jpeg',
    number: '03 — Voorbereiden',
  },
];
---

<Layout title="Diensten | EVS Vloerverwarming" transparentHeader={true}>
  <Header />
  <main>
    <PageHeader
      eyebrow="Wat wij doen"
      title={`Compleet pakket voor<br/><span class="text-primary">vloerrenovatie</span>.`}
      lead="Van voorbereiding tot afwerking — alles in eigen beheer, in één werkdag."
      image="/images/hero-4.webp"
      imageAlt="Diensten EVS Vloerverwarming"
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Diensten' }]}
    />

    <section class="py-20 lg:py-28 bg-white">
      <div class="container">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {services.map((s, i) => (
            <div class={`reveal stagger-${i + 1}`}>
              <ServiceCard {...s} />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="relative py-20 lg:py-28 bg-stone-50 overflow-hidden">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center">
          <SectionHeading
            eyebrow="Advies op maat"
            title={`Elke vloer is anders.<br/>Jouw situatie verdient <span class="text-primary">maatwerk</span>.`}
            lead="Niet zeker welke dienst je nodig hebt? Bel Erik of stuur je situatie door — we denken graag mee."
            align="center"
          />
          <div class="reveal stagger-3 mt-10 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="/contact" class="btn-pill btn-primary">
              Neem contact op
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </a>
            <a href="/offerte" class="btn-pill btn-outline">
              Direct offerte aanvragen
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
