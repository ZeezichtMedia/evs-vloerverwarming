---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ServiceCard from '../components/ServiceCard.astro';

// Service data
const services = [
  {
    title: 'Vloerverwarming frezen',
    description: 'Specialist in het stofvrij invrezen van vloerverwarming in zandcement, beton of anhydriet dekloeren. Snel, vakkundig en zonder overlast in uw woning.',
    link: '/vloerverwarming-frezen',
    image: 'https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-8_result.webp'
  },
  {
    title: 'Dichtsmeren & Egaliseren',
    description: 'Na het frezen kunnen wij de sleuven vakkundig dichtsmeren of de gehele voer egaliseren voor een perfect glad eindresultaat, klaar voor de eindvloer.',
    link: '/dichtsmeren-egaliseren',
    image: 'https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/07/Vloer-dichtsmeren.webp'
  },
  {
    title: 'Vloeren verwijderen & schuren',
    description: 'Oude vloerbedekking, lijmresten of coatings verwijderen? Wij schuren uw vloer kaal en maken deze gereed voor verdere bewerking.',
    link: '/vloeren-schuren',
    image: 'https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/WhatsApp-Image-2025-07-23-at-08.25.07-1-1.jpeg'
  }
];

const usps = [
  { 
    title: 'Regio Zeeland & W-Brabant', 
    text: 'Snel ter plaatse en bekend in de regio.',
    path: 'M17.657 16.657L13 21.314l-4.657-4.657a8 8 0 0111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z'
  },
  { 
    title: '100% Stofvrij', 
    text: 'Geavanceerde afzuiging voor een schoon huis.',
    path: 'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z'
  },
  { 
    title: 'Snelle beschikbaarheid', 
    text: 'Geen maanden wachten, wij schakelen snel.',
    path: 'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'
  },
  { 
    title: 'Eerlijke prijzen', 
    text: 'Transparante offertes zonder verrassingen.',
    path: 'M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z'
  }
];
---

<Layout title="EVS Vloerverwarming | Specialisten in frezen en betonwerken">
  <Header />
  
  <main>
    <Hero />

    <!-- Intro Section -->
    <section class="py-16 md:py-24 bg-white relative">
      <div class="container">
        <div class="flex flex-col lg:flex-row items-center gap-12 lg:gap-20">
          <div class="lg:w-1/2 relative group">
            <!-- Decorative shapes behind the grid -->
            <div class="absolute -top-6 -left-6 w-32 h-32 bg-primary/5 rounded-tl-[3rem] z-0"></div>
            <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-navy/5 rounded-br-[3rem] z-0"></div>
            
            <div class="relative z-10 flex gap-4 h-[400px] md:h-[500px]">
              <!-- Large Left Image -->
              <img 
                src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-6_result.webp" 
                alt="Vakman aan het werk" 
                class="w-2/3 h-full object-cover rounded-2xl shadow-xl transition-transform duration-500 hover:scale-[1.02]"
              />
              <!-- Right Stacked Images -->
              <div class="w-1/3 flex flex-col gap-4">
                <img 
                  src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-2_result.webp" 
                  alt="Vloerverwarming verdeler" 
                  class="h-1/2 w-full object-cover rounded-2xl shadow-xl transition-transform duration-500 hover:scale-[1.02]"
                />
                <img 
                  src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-5_result.webp" 
                  alt="Vloerverwarming in woonkamer" 
                  class="h-1/2 w-full object-cover rounded-2xl shadow-xl transition-transform duration-500 hover:scale-[1.02]"
                />
              </div>
            </div>
          </div>
          <div class="lg:w-1/2">
            <span class="text-primary font-bold uppercase tracking-widest text-xs md:text-sm mb-2 block">Over EVS Vloerverwarming</span>
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-black text-navy mb-6 leading-tight">Ervaring waar u op kunt <span class="text-primary">bouwen</span></h2>
            <p class="text-gray-600 leading-relaxed mb-6 text-lg">
              Of het nu gaat om een enkele ruimte of een complete woning: bij EVS Vloerverwarming bent u aan het juiste adres. Sinds 2001 is Erik van Sighem de drijvende kracht achter EvS.
            </p>
            <p class="text-gray-600 leading-relaxed mb-8">
              Er wordt uitsluitend gewerkt met professionele apparatuur om stofvrij te kunnen frezen in beton, zandcement en andere dekvloeren. Kwaliteit en netheid staan bij EvS op nummer één.
            </p>
            <a href="/contact" class="inline-flex items-center gap-2 text-navy font-bold border-b-2 border-primary pb-1 hover:text-primary transition-all hover:gap-3">
              Meer over EvS 
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="py-20 md:py-28 bg-gray-50 relative">
      <div class="container relative z-10">
        <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
          <span class="text-primary font-bold uppercase tracking-widest text-xs md:text-sm mb-3 block">Diensten</span>
          <h2 class="text-3xl md:text-5xl font-black text-navy mb-6">Waarmee kunnen we u helpen?</h2>
          <p class="text-gray-600 text-lg">Complete oplossingen voor vloerrenovatie en comfort.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
          {services.map(service => (
            <ServiceCard {...service} />
          ))}
        </div>
      </div>
    </section>

    <!-- USPs Section -->
    <section class="py-24 bg-gray-50 text-center relative overflow-hidden">
      <div class="container relative z-10">
        <h2 class="text-3xl md:text-4xl font-black mb-16 text-navy">Waarom kiezen voor EVS?</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
          {usps.map(usp => (
            <div class="group p-8 rounded-2xl bg-white border border-gray-100 shadow-lg hover:shadow-xl transition-all duration-300 hover:-translate-y-2">
              <div class="h-14 w-14 mx-auto mb-6 flex items-center justify-center rounded-xl bg-primary/10 text-primary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={usp.path} />
                </svg>
              </div>
              <h3 class="text-xl font-bold mb-3 text-navy">{usp.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed">{usp.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <!-- CTA Section -->
    <section class="py-24 bg-primary relative overflow-hidden">
        <!-- Modern Geometric Background -->
        <div class="absolute inset-0 opacity-10">
            <div class="absolute inset-0 bg-[radial-gradient(#ffffff33_1px,transparent_1px)] [background-size:20px_20px]"></div>
            <div class="absolute right-0 bottom-0 -mb-32 -mr-32 w-96 h-96 rounded-full bg-white/20 blur-3xl"></div>
            <div class="absolute left-0 top-0 -mt-32 -ml-32 w-96 h-96 rounded-full bg-navy/20 blur-3xl"></div>
        </div>

        <div class="container relative z-10 text-center">
            <h2 class="text-3xl md:text-5xl font-black text-white mb-6 leading-tight">Klaar voor warmte en comfort?</h2>
            <p class="text-xl text-white/90 mb-10 max-w-2xl mx-auto font-medium">
                Vraag vrijblijvend een offerte aan. EvS adviseert u graag.
            </p>
            <div class="flex flex-col sm:flex-row gap-6 justify-center">
                <a href="/offerte" class="group bg-white text-primary font-bold py-4 px-10 rounded-full text-lg shadow-2xl hover:bg-gray-50 transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2">
                    Offerte aanvragen
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                </a>
                <a href="tel:+31612345678" class="bg-transparent border-2 border-white text-white font-bold py-4 px-10 rounded-full text-lg hover:bg-white/10 transition-all hover:border-white/80">
                    Bellen
                </a>
            </div>
        </div>
    </section>
  </main>

  <Footer />
</Layout>
