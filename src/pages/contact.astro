---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | EVS Vloerverwarming">
  <Header />
  <main>
    <!-- Page Header -->
    <section class="relative py-24 min-h-[300px] flex items-center overflow-hidden">
        <div class="absolute inset-0 z-0">
           <!-- Using a relevant contact/work image -->
            <img 
              src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-8_result.webp" 
              alt="Contact EVS" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/30"></div>
        </div>
        <div class="container relative z-10 text-white text-center">
            <h1 class="text-4xl md:text-5xl font-black mb-4 drop-shadow-lg text-white">Contact</h1>
            <p class="text-xl text-white font-medium max-w-2xl mx-auto drop-shadow-md">
                Vragen of een offerte? EvS staat voor u klaar.
            </p>
        </div>
    </section>

    <section class="py-20 bg-gray-50">
        <div class="container">
            <div class="grid lg:grid-cols-2 gap-12 max-w-5xl mx-auto">
                <!-- Contact Info Card -->
                <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 h-full">
                    <h2 class="text-2xl font-bold text-navy mb-6">Contactgegevens</h2>
                    <p class="text-gray-600 mb-8 leading-relaxed">
                        EvS Vloerverwarming is actief in heel Zeeland en West-Brabant. Bel gerust voor direct advies.
                    </p>
                    
                    <div class="space-y-6">
                        <div class="flex items-start gap-4">
                            <div class="bg-primary/10 p-3 rounded-full text-primary shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13 21.314l-4.657-4.657a8 8 0 0111.314 0z" />
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-navy text-lg">Adres</h3>
                                <p class="text-gray-600">Zoutelande, Zeeland</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="bg-primary/10 p-3 rounded-full text-primary shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-navy text-lg">Telefoon</h3>
                                <a href="tel:+31612345678" class="text-gray-600 hover:text-primary transition-colors font-medium">06 - 12 34 56 78</a>
                                <p class="text-sm text-gray-500 mt-1">Ook beschikbaar via WhatsApp</p>
                            </div>
                        </div>

                        <div class="flex items-start gap-4">
                            <div class="bg-primary/10 p-3 rounded-full text-primary shrink-0">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-navy text-lg">E-mail</h3>
                                <a href="mailto:info@evs-vloerverwarming.nl" class="text-gray-600 hover:text-primary transition-colors font-medium">info@evs-vloerverwarming.nl</a>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Form Card -->
                <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100 h-full">
                    <h2 class="text-2xl font-bold text-navy mb-6">Stuur een bericht</h2>
                    <form class="space-y-5">
                         <div>
                             <label class="block text-sm font-bold text-navy mb-2">Naam</label>
                             <input type="text" class="w-full border border-gray-200 bg-gray-50 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder-gray-400" placeholder="Uw naam" />
                         </div>
                         <div>
                             <label class="block text-sm font-bold text-navy mb-2">E-mailadres</label>
                             <input type="email" class="w-full border border-gray-200 bg-gray-50 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder-gray-400" placeholder="uw@email.nl" />
                         </div>
                         <div>
                             <label class="block text-sm font-bold text-navy mb-2">Bericht</label>
                             <textarea rows="5" class="w-full border border-gray-200 bg-gray-50 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder-gray-400" placeholder="Hoe kan EvS u helpen?"></textarea>
                         </div>
                         <button type="submit" class="bg-primary text-white font-bold py-4 px-6 rounded-lg w-full hover:bg-primary-dark transition-all transform hover:-translate-y-1 shadow-md">Bericht versturen</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
  </main>
  <Footer />
</Layout>
