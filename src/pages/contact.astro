---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
---

<Layout
  title="Contact | EVS Vloerverwarming"
  description="Direct in gesprek met Erik van Sighem. Bel 06 13 56 45 46, mail of stuur een bericht. Persoonlijk contact — geen callcenter. Zeeland & West-Brabant."
  ogImage="/images/hero-2.webp"
  transparentHeader={true}
>
  <Header />
  <main>
    <PageHeader
      eyebrow="Contact"
      title={`Laat je <span class="text-primary">horen</span>.`}
      lead="Persoonlijk contact, geen callcenter. Bel, mail of stuur een bericht — je spreekt direct met Erik."
      image="/images/hero-2.webp"
      imageAlt="Contact EVS"
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
    />

    <section class="py-20 lg:py-28 bg-stone-50">
      <div class="container max-w-6xl">
        <div class="grid lg:grid-cols-[1fr_1.2fr] gap-8">
          <!-- Contact info -->
          <div class="reveal bg-white rounded-3xl p-8 lg:p-10 border border-stone-200 shadow-xl relative overflow-hidden">
            <!-- Thin accent top-bar -->
            <div class="absolute top-0 left-0 right-0 h-1 bg-primary"></div>

            <span class="inline-flex items-center gap-2 text-primary font-heading font-bold text-[11px] uppercase tracking-[0.22em] mb-4">
              <span class="pulse-dot"></span>
              Bereikbaar
            </span>
            <h2 class="font-heading font-black text-ink-500 text-3xl lg:text-4xl leading-tight mb-4">
              Direct in gesprek met <span class="text-primary">Erik</span>.
            </h2>
            <p class="text-slate-600 leading-relaxed mb-10">
              EvS Vloerverwarming is actief in heel Zeeland en West-Brabant. Bel gerust voor direct advies — ook buiten kantooruren bereikbaar via WhatsApp.
            </p>

            <div class="space-y-2">
              <a href="tel:+31613564546" class="group flex items-center gap-4 -mx-3 px-3 py-3 rounded-xl hover:bg-stone-50 transition-colors">
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary grid place-items-center group-hover:bg-primary group-hover:text-white transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </span>
                <div class="min-w-0">
                  <p class="text-[11px] text-stone-500 uppercase tracking-[0.18em] font-heading font-bold mb-0.5">Telefoon / WhatsApp</p>
                  <p class="font-heading font-bold text-lg text-ink-500 group-hover:text-primary transition-colors">06 13 56 45 46</p>
                </div>
              </a>

              <a href="mailto:info@evs-vloerverwarming.nl" class="group flex items-center gap-4 -mx-3 px-3 py-3 rounded-xl hover:bg-stone-50 transition-colors">
                <span class="shrink-0 w-11 h-11 rounded-xl bg-primary/10 text-primary grid place-items-center group-hover:bg-primary group-hover:text-white transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </span>
                <div class="min-w-0">
                  <p class="text-[11px] text-stone-500 uppercase tracking-[0.18em] font-heading font-bold mb-0.5">E-mail</p>
                  <p class="font-heading font-bold text-base text-ink-500 group-hover:text-primary transition-colors truncate">info@evs-vloerverwarming.nl</p>
                </div>
              </a>

              <div class="flex items-center gap-4 -mx-3 px-3 py-3">
                <span class="shrink-0 w-11 h-11 rounded-xl bg-stone-100 text-stone-500 grid place-items-center">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"/><path d="M15 10a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/>
                  </svg>
                </span>
                <div>
                  <p class="text-[11px] text-stone-500 uppercase tracking-[0.18em] font-heading font-bold mb-0.5">Werkgebied</p>
                  <p class="font-heading font-bold text-base text-ink-500">Zeeland & West-Brabant</p>
                  <p class="text-xs text-stone-500 mt-0.5">Gevestigd in Zoutelande</p>
                </div>
              </div>
            </div>

            <div class="mt-8 pt-6 border-t border-stone-200 flex items-center gap-3">
              <span class="pulse-dot"></span>
              <span class="text-xs uppercase tracking-widest font-heading font-bold text-stone-500">Doorgaans binnen 2 uur reactie</span>
            </div>
          </div>

          <!-- Form -->
          <div class="reveal stagger-2 bg-white rounded-3xl shadow-xl border border-stone-200 p-8 lg:p-10">
            <span class="eyebrow mb-4 inline-flex">Stuur een bericht</span>
            <h2 class="font-heading font-black text-ink-500 text-3xl lg:text-4xl leading-tight mb-8">
              Jouw vraag, <span class="text-primary">onze aandacht</span>.
            </h2>

            <!-- Success -->
            <div id="contact-success" class="hidden text-center py-10">
              <div class="w-14 h-14 mx-auto mb-5 rounded-full bg-green-100 text-green-600 grid place-items-center text-2xl font-bold">✓</div>
              <h3 class="font-heading font-black text-2xl text-ink-500 mb-2">Bericht verstuurd!</h3>
              <p class="text-slate-600">We nemen zo snel mogelijk contact met je op.</p>
            </div>

            <form id="contact-form" class="space-y-5" novalidate>
              <!-- Honeypot (verborgen voor mensen) -->
              <div style="position:absolute;left:-9999px;" aria-hidden="true">
                <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
              </div>

              <div class="grid sm:grid-cols-2 gap-5">
                <div>
                  <label class="block text-xs font-heading font-bold text-ink-500 uppercase tracking-[0.15em] mb-2" for="contact-naam">Naam*</label>
                  <input id="contact-naam" type="text" name="naam" required class="w-full bg-stone-50 border-2 border-stone-200 rounded-xl px-4 py-3.5 focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="Je naam" />
                </div>
                <div>
                  <label class="block text-xs font-heading font-bold text-ink-500 uppercase tracking-[0.15em] mb-2" for="contact-telefoon">Telefoon</label>
                  <input id="contact-telefoon" type="tel" name="telefoon" class="w-full bg-stone-50 border-2 border-stone-200 rounded-xl px-4 py-3.5 focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="06 13 56 45 46" />
                </div>
              </div>
              <div>
                <label class="block text-xs font-heading font-bold text-ink-500 uppercase tracking-[0.15em] mb-2" for="contact-email">E-mailadres*</label>
                <input id="contact-email" type="email" name="email" required class="w-full bg-stone-50 border-2 border-stone-200 rounded-xl px-4 py-3.5 focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all" placeholder="jij@email.nl" />
              </div>
              <div>
                <label class="block text-xs font-heading font-bold text-ink-500 uppercase tracking-[0.15em] mb-2" for="contact-bericht">Bericht*</label>
                <textarea id="contact-bericht" name="bericht" rows="6" required class="w-full bg-stone-50 border-2 border-stone-200 rounded-xl px-4 py-3.5 focus:bg-white focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition-all resize-none" placeholder="Hoe kan EvS je helpen?"></textarea>
              </div>

              <div id="contact-error" class="hidden bg-red-50 border border-red-200 text-red-700 rounded-xl px-4 py-3 text-sm"></div>

              <button id="contact-submit" type="submit" class="btn-pill btn-primary w-full justify-center py-4 disabled:opacity-60 disabled:cursor-not-allowed">
                <span data-label>Bericht versturen</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </button>
              <p class="text-xs text-stone-500 text-center">
                Voor een directe prijsindicatie: <a href="/offerte" class="text-primary font-bold hover:underline">vul het offertestappenplan in</a>.
              </p>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />

  <script is:inline>
    (function () {
      const form = document.getElementById('contact-form');
      if (!form || form.dataset.wired === 'true') return;
      form.dataset.wired = 'true';

      const submitBtn = document.getElementById('contact-submit');
      const btnLabel = submitBtn.querySelector('[data-label]');
      const errorBox = document.getElementById('contact-error');
      const successBox = document.getElementById('contact-success');

      function showError(msg) {
        errorBox.textContent = msg;
        errorBox.classList.remove('hidden');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        errorBox.classList.add('hidden');

        const data = Object.fromEntries(new FormData(form).entries());
        if (!data.naam || !data.email || !data.bericht) {
          showError('Vul alle verplichte velden in.');
          return;
        }

        submitBtn.disabled = true;
        btnLabel.textContent = 'Versturen...';

        try {
          const res = await fetch('/api/send-contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });
          if (!res.ok) {
            const body = await res.json().catch(() => ({}));
            throw new Error(body.error || 'Versturen mislukt.');
          }
          form.classList.add('hidden');
          successBox.classList.remove('hidden');
          window.scrollTo({ top: successBox.offsetTop - 120, behavior: 'smooth' });
        } catch (err) {
          showError(err.message || 'Er ging iets mis. Probeer het later opnieuw.');
          submitBtn.disabled = false;
          btnLabel.textContent = 'Bericht versturen';
        }
      });
    })();
  </script>
</Layout>
