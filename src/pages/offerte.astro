---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import OfferteForm from '../components/OfferteForm.astro';
---

<Layout title="Offerte aanvragen | EVS Vloerverwarming" transparentHeader={true}>
  <Header />
  <main>
    <PageHeader
      eyebrow="Offerte in 8 uur"
      title={`Ontvang je<br/><span class="text-primary">prijs op maat</span>.`}
      lead="Vul binnen een minuut het stappenplan in. Je ontvangt dezelfde werkdag nog een complete prijsindicatie."
      image="/images/hero-interior.jpg"
      imageAlt="Vloerverwarming resultaat"
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Offerte' }]}
    />

    <section class="py-20 lg:py-28 bg-stone-50 relative">
      <div class="container max-w-3xl relative">
        <div class="reveal">
          <OfferteForm />
        </div>

        <div class="reveal stagger-2 mt-10 grid sm:grid-cols-3 gap-4 text-center">
          <div class="bg-white rounded-2xl p-5 border border-stone-200">
            <div class="font-heading font-black text-primary text-3xl leading-none mb-1">8u</div>
            <div class="text-xs text-stone-500 uppercase tracking-widest font-heading font-bold">Reactietijd</div>
          </div>
          <div class="bg-white rounded-2xl p-5 border border-stone-200">
            <div class="font-heading font-black text-primary text-3xl leading-none mb-1">€0</div>
            <div class="text-xs text-stone-500 uppercase tracking-widest font-heading font-bold">Vrijblijvend</div>
          </div>
          <div class="bg-white rounded-2xl p-5 border border-stone-200">
            <div class="font-heading font-black text-primary text-3xl leading-none mb-1">1:1</div>
            <div class="text-xs text-stone-500 uppercase tracking-widest font-heading font-bold">Persoonlijk</div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
