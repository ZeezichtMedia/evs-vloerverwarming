---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import OfferteForm from '../components/OfferteForm.astro';
---

<Layout title="Offerte Aanvragen | EVS Vloerverwarming">
  <Header />
  <main>
    <!-- Page Header -->
    <section class="relative py-24 min-h-[300px] flex items-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img
              src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-07-5_result.webp"
              alt="Vloerverwarming resultaat"
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/30"></div>
        </div>
        <div class="container relative z-10 text-white text-center">
            <h1 class="text-4xl md:text-5xl font-black mb-4 drop-shadow-lg text-white">Vraag offerte aan</h1>
            <p class="text-xl text-white font-medium max-w-2xl mx-auto drop-shadow-md">
                Vul binnen een minuut het formulier in en ontvang binnen 8 uur een prijsindicatie.
            </p>
        </div>
    </section>

    <section class="py-20 bg-gray-50">
      <div class="container max-w-3xl">
        <OfferteForm />
      </div>
    </section>
  </main>
  <Footer />
</Layout>
