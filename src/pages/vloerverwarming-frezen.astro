---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Vloerverwarming Frezen | EVS Vloerverwarming">
  <Header />
  <main>
    <!-- Page Header -->
    <!-- Page Header -->
    <section class="relative py-24 min-h-[400px] flex items-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img 
              src="https://www.evs-vloerverwarming.nl/wp-content/uploads/2025/09/PHOTO-2025-07-14-20-22-08_result.webp" 
              alt="Vloerverwarming frezen" 
              class="w-full h-full object-cover"
            />
            <div class="absolute inset-0 bg-black/30"></div>
        </div>
        <div class="container relative z-10 text-white text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-black mb-4 drop-shadow-lg text-white">Vloerverwarming Frezen</h1>
            <p class="text-xl text-white font-medium max-w-2xl drop-shadow-md">Stofvrij en vakkundig uw vloerverwarming ingefreesd.</p>
        </div>
    </section>

    <!-- Content -->
    <section class="py-20 bg-gray-50">
        <div class="container">
            <div class="flex flex-col lg:flex-row gap-12">
                <div class="lg:w-2/3">
                    <div class="bg-white p-8 rounded-2xl shadow-lg mb-12 border border-gray-100">
                        <h2 class="text-3xl font-bold text-navy mb-6">Stofvrij frezen door EvS</h2>
                        <p class="text-gray-600 mb-6 leading-relaxed">
                            Bij het frezen van vloerverwarming worden er sleuven gemaakt in uw bestaande dekvloer. Dit gebeurt met een speciale vloerenfreesmachine die is aangesloten op een krachtige industriële stofzuiger. Hierdoor werkt EvS nagenoeg <strong>100% stofvrij</strong>. U hoeft dus niet bang te zijn voor stof in uw meubels of gordijnen.
                        </p>
                        <p class="text-gray-600 mb-6 leading-relaxed">
                            Het grote voordeel van frezen is dat de bestaande dekvloer niet verwijderd hoeft te worden. De buizen liggen direct tegen het oppervlak, wat zorgt voor een zeer snelle opwarming van de ruimte en een hoog rendement.
                        </p>
                    </div>

                    <h3 class="text-2xl font-bold text-navy mb-6">Het proces in 3 stappen</h3>
                    <div class="space-y-6 mb-12">
                        <div class="flex gap-4">
                            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold">1</div>
                            <div>
                                <h4 class="font-bold text-navy text-lg mb-2">Sleuven frezen</h4>
                                <p class="text-gray-600">Er worden sleuven van ca. 17mm diep gefreesd in een slakkenhuispatroon. Dit zorgt voor een optimale warmteverdeling. De hart-op-hart afstand (meestal 10cm of 15cm) wordt bepaald aan de hand van uw warmtebehoefte (hoofdverwarming of bijverwarming).</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold">2</div>
                            <div>
                                <h4 class="font-bold text-navy text-lg mb-2">Buizen leggen</h4>
                                <p class="text-gray-600">In de gefreesde sleuven worden hoogwaardige 16mm vloerverwarmingsbuizen gelegd. EvS gebruikt uitsluitend diffusiedichte buizen van topkwaliteit die jarenlang meegaan zonder verstoppingen.</p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div class="flex-shrink-0 w-10 h-10 rounded-full bg-primary text-white flex items-center justify-center font-bold">3</div>
                            <div>
                                <h4 class="font-bold text-navy text-lg mb-2">Aansluiten en afwerken</h4>
                                <p class="text-gray-600">De groepen worden aangesloten op de verdeler. Na het testen van het systeem op druk kunnen de sleuven worden dichtgesmeerd. <a href="/dichtsmeren-egaliseren" class="text-primary hover:underline font-bold">Lees meer over dichtsmeren</a>.</p>
                            </div>
                        </div>
                    </div>
                    
                    <h3 class="text-2xl font-bold text-navy mb-6">Technische specificaties</h3>
                    <ul class="grid sm:grid-cols-2 gap-4 mb-12">
                        <li class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 flex items-center gap-2">
                            <span class="text-primary font-bold">✓</span> Diepte sleuven: ± 17mm
                        </li>
                        <li class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 flex items-center gap-2">
                            <span class="text-primary font-bold">✓</span> Buisdikte: 14mm of 16mm
                        </li>
                        <li class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 flex items-center gap-2">
                            <span class="text-primary font-bold">✓</span> Patroon: Slakkenhuis
                        </li>
                        <li class="bg-white p-4 rounded-lg shadow-sm border border-gray-100 flex items-center gap-2">
                            <span class="text-primary font-bold">✓</span> Geschikt voor: Beton, Zandcement, Anhydriet
                        </li>
                    </ul>

                    <!-- FAQ Section -->
                    <h3 class="text-2xl font-bold text-navy mb-6">Veelgestelde vragen</h3>
                    <div class="space-y-4 mb-12">
                        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-4 [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex cursor-pointer items-center justify-between gap-1.5 font-bold text-navy">
                                <span>Hoe lang duren de werkzaamheden?</span>
                                <span class="shrink-0 rounded-full bg-white p-1.5 text-navy sm:p-3 group-open:bg-primary group-open:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 transition duration-300 group-open:-rotate-180" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="mt-4 leading-relaxed text-gray-600">
                                In de meeste gevallen is de installatie, inclusief frezen, leggen van de buizen en aansluiten van de verdeler, binnen één dag afgerond (afhankelijk van het aantal vierkante meters).
                            </div>
                        </details>

                        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-4 [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex cursor-pointer items-center justify-between gap-1.5 font-bold text-navy">
                                <span>Is er echt geen stofoverlast?</span>
                                <span class="shrink-0 rounded-full bg-white p-1.5 text-navy sm:p-3 group-open:bg-primary group-open:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 transition duration-300 group-open:-rotate-180" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="mt-4 leading-relaxed text-gray-600">
                                EvS werkt met geavanceerde freesmachines die direct zijn gekoppeld aan zware industriële stofzuigers. Hierdoor wordt >99% van het stof direct afgezogen. Uw woning blijft schoon.
                            </div>
                        </details>

                        <details class="group bg-white rounded-xl shadow-sm border border-gray-100 p-4 [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex cursor-pointer items-center justify-between gap-1.5 font-bold text-navy">
                                <span>Moet de woning leeg zijn?</span>
                                <span class="shrink-0 rounded-full bg-white p-1.5 text-navy sm:p-3 group-open:bg-primary group-open:text-white transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0 transition duration-300 group-open:-rotate-180" viewBox="0 0 20 20" fill="currentColor">
                                        <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="mt-4 leading-relaxed text-gray-600">
                                De vloer waar gefreesd wordt moet volledig leeg en bezemschoon zijn. Keukens, vaste kasten of trappen kunnen uiteraard blijven staan; hier wordt netjes langs gefreesd.
                            </div>
                        </details>
                    </div>

                    <a href="/offerte" class="inline-block bg-primary text-white font-bold py-4 px-10 rounded-full shadow-lg hover:bg-primary-dark transition-colors transform hover:-translate-y-1">
                        Vraag vrijblijvend offerte aan
                    </a>
                </div>
                <div class="lg:w-1/3">
                    <div class="bg-white p-6 rounded-xl shadow-lg border border-gray-100 sticky top-24">
                        <h3 class="text-xl font-bold text-navy mb-4 border-b border-gray-100 pb-2">Gerelateerde diensten</h3>
                        <ul class="space-y-3">
                            <li><a href="/dichtsmeren-egaliseren" class="text-gray-600 hover:text-primary block py-1 transition-colors flex items-center justify-between group">
                                Dichtsmeren & Egaliseren <span class="text-gray-300 group-hover:text-primary">→</span>
                            </a></li>
                            <li><a href="/vloeren-schuren" class="text-gray-600 hover:text-primary block py-1 transition-colors flex items-center justify-between group">
                                Vloeren schuren <span class="text-gray-300 group-hover:text-primary">→</span>
                            </a></li>
                            <li><a href="/contact" class="text-gray-600 hover:text-primary block py-1 transition-colors flex items-center justify-between group">
                                Contact opnemen <span class="text-gray-300 group-hover:text-primary">→</span>
                            </a></li>
                        </ul>

                         <div class="mt-8 bg-primary/5 rounded-lg p-6 text-center">
                            <p class="font-bold text-navy mb-2">Heeft u vragen?</p>
                            <p class="text-sm text-gray-600 mb-4">Bel direct met Erik voor advies.</p>
                            <a href="tel:+31612345678" class="text-primary font-bold text-lg hover:underline">06 - 12 34 56 78</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
  </main>
  <Footer />
</Layout>
