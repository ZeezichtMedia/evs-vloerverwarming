---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeader from '../components/ui/PageHeader.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import FAQItem from '../components/ui/FAQItem.astro';

const steps = [
  {
    title: 'Sleuven frezen',
    description: 'Er worden sleuven van ca. 17mm diep gefreesd in een slakkenhuispatroon. Dit zorgt voor een optimale warmteverdeling. De hart-op-hart afstand (meestal 10cm of 15cm) wordt bepaald aan de hand van je warmtebehoefte.',
  },
  {
    title: 'Buizen leggen',
    description: 'In de gefreesde sleuven worden hoogwaardige 16mm vloerverwarmingsbuizen gelegd. EvS gebruikt uitsluitend diffusiedichte buizen van topkwaliteit die jarenlang meegaan zonder verstoppingen.',
  },
  {
    title: 'Aansluiten & afwerken',
    description: 'De groepen worden aangesloten op de verdeler. Na het testen van het systeem op druk kunnen de sleuven worden dichtgesmeerd.',
  },
];

const specs = [
  { label: 'Diepte sleuven', value: '± 17mm' },
  { label: 'Buisdikte', value: '14 of 16mm' },
  { label: 'Patroon', value: 'Slakkenhuis' },
  { label: 'Geschikt voor', value: 'Beton · Zandcement · Anhydriet' },
];
---

<Layout
  title="Vloerverwarming Frezen | Stofvrij — EVS Vloerverwarming"
  description="Stofvrij vloerverwarming frezen in zandcement, beton en anhydriet. Hoog rendement, installatie meestal binnen één dag. Specialist in Zeeland en West-Brabant."
  ogImage="/images/frezen.webp"
  transparentHeader={true}
>
  <Header />
  <main>
    <PageHeader
      eyebrow="Dienst 01 — Frezen"
      title={`Vloerverwarming<br/><span class="text-primary">stofvrij</span> gefreesd.`}
      lead="Hoogrendement-installatie zonder dat je meubels, gordijnen of leidingen verplaatst hoeven worden."
      image="/images/frezen.webp"
      imageAlt="Vloerverwarming frezen"
      breadcrumb={[{ label: 'Home', href: '/' }, { label: 'Diensten', href: '/diensten' }, { label: 'Frezen' }]}
    />

    <section class="py-20 lg:py-28 bg-white">
      <div class="container">
        <div class="grid lg:grid-cols-[2fr_1fr] gap-12 lg:gap-16">
          <div class="min-w-0">
            <div class="reveal">
              <span class="eyebrow mb-4 inline-flex">Hoe wij werken</span>
              <h2 class="font-heading font-black text-4xl lg:text-5xl text-ink-500 leading-tight mb-6 text-balance">
                Stofvrij frezen, <span class="text-primary">écht</span>.
              </h2>
              <p class="text-slate-600 text-lg leading-relaxed mb-5">
                Bij het frezen van vloerverwarming worden er sleuven gemaakt in je bestaande dekvloer. Dit gebeurt met een speciale vloerenfreesmachine die is aangesloten op een krachtige industriële stofzuiger. Hierdoor werkt EvS nagenoeg <strong class="text-ink-500">100% stofvrij</strong> — geen stof in meubels of gordijnen.
              </p>
              <p class="text-slate-600 text-lg leading-relaxed">
                Het grote voordeel van frezen is dat de bestaande dekvloer niet verwijderd hoeft te worden. De buizen liggen direct tegen het oppervlak, wat zorgt voor een zeer snelle opwarming en een hoog rendement.
              </p>
            </div>

            <div class="mt-14 lg:mt-20">
              <h3 class="reveal font-heading font-black text-3xl text-ink-500 mb-8">Het proces in 3 stappen</h3>
              <div class="space-y-5">
                {steps.map((step, i) => (
                  <div class={`reveal stagger-${i + 1} group relative bg-stone-50 rounded-2xl p-6 lg:p-8 border border-stone-200 hover:border-primary/50 transition-colors`}>
                    <div class="flex items-start gap-5 lg:gap-7">
                      <span class="shrink-0 font-heading font-black text-primary text-5xl lg:text-6xl leading-none">
                        {String(i + 1).padStart(2, '0')}
                      </span>
                      <div>
                        <h4 class="font-heading font-black text-xl lg:text-2xl text-ink-500 mb-2">
                          {step.title}
                        </h4>
                        <p class="text-slate-600 leading-relaxed">
                          {step.description}
                          {i === 2 && (
                            <> <a href="/dichtsmeren-egaliseren" class="text-primary font-bold hover:underline">Lees meer over dichtsmeren →</a></>
                          )}
                        </p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-14 lg:mt-20">
              <h3 class="reveal font-heading font-black text-3xl text-ink-500 mb-8">Technische specs</h3>
              <div class="grid sm:grid-cols-2 gap-3">
                {specs.map((spec, i) => (
                  <div class={`reveal stagger-${i + 1} bg-stone-50 border border-stone-200 rounded-2xl p-5 flex items-center justify-between hover:border-primary/50 transition-colors`}>
                    <span class="text-stone-500 font-heading font-bold text-xs uppercase tracking-[0.2em]">{spec.label}</span>
                    <span class="font-heading font-black text-ink-500 text-right">{spec.value}</span>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-14 lg:mt-20">
              <h3 class="reveal font-heading font-black text-3xl text-ink-500 mb-8">Veelgestelde vragen</h3>
              <div class="space-y-3">
                <FAQItem question="Hoe lang duren de werkzaamheden?">
                  In de meeste gevallen is de installatie — inclusief frezen, leggen van de buizen en aansluiten van de verdeler — binnen één dag afgerond (afhankelijk van het aantal vierkante meters).
                </FAQItem>
                <FAQItem question="Is er echt geen stofoverlast?">
                  EvS werkt met geavanceerde freesmachines die direct zijn gekoppeld aan zware industriële stofzuigers. Hierdoor wordt >99% van het stof direct afgezogen. Je woning blijft schoon.
                </FAQItem>
                <FAQItem question="Moet de woning leeg zijn?">
                  De vloer waar gefreesd wordt moet volledig leeg en bezemschoon zijn. Keukens, vaste kasten of trappen kunnen uiteraard blijven staan; hier wordt netjes langs gefreesd.
                </FAQItem>
              </div>
            </div>

            <div class="mt-14 reveal">
              <a href="/offerte" class="btn-pill btn-primary">
                Vraag vrijblijvend offerte aan
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>

          <!-- Sidebar -->
          <aside class="lg:sticky lg:top-28 h-fit space-y-5">
            <div class="reveal-right bg-primary text-white rounded-3xl p-7 overflow-hidden relative shadow-xl shadow-primary/25">
              <div class="absolute inset-0 opacity-40 pointer-events-none" style="background: radial-gradient(ellipse at top right, rgba(255, 255, 255, 0.2), transparent 65%);"></div>
              <div class="relative">
                <span class="inline-flex items-center gap-2 text-white/85 font-heading font-bold text-[11px] uppercase tracking-[0.22em] mb-3">
                  <span class="pulse-dot"></span>
                  Direct advies
                </span>
                <h4 class="font-heading font-black text-white text-2xl mb-3">Bel met Erik</h4>
                <p class="text-white/85 text-sm mb-6 leading-relaxed">Persoonlijk advies van de specialist zelf — geen callcenter.</p>
                <a href="tel:+31613564546" class="btn-pill btn-white w-full justify-center">
                  06 13 56 45 46
                </a>
              </div>
            </div>

            <div class="reveal-right stagger-2 bg-white border border-stone-200 rounded-3xl p-7">
              <h4 class="font-heading font-bold text-ink-500 text-sm uppercase tracking-[0.18em] mb-5 pb-4 border-b border-stone-200">Gerelateerde diensten</h4>
              <ul class="space-y-3">
                <li><a href="/dichtsmeren-egaliseren" class="group flex items-center justify-between text-slate-600 hover:text-primary py-2 transition-colors">
                  <span>Dichtsmeren & Egaliseren</span>
                  <span class="text-stone-300 group-hover:text-primary group-hover:translate-x-1 transition-all">→</span>
                </a></li>
                <li><a href="/vloeren-schuren" class="group flex items-center justify-between text-slate-600 hover:text-primary py-2 transition-colors">
                  <span>Vloeren schuren</span>
                  <span class="text-stone-300 group-hover:text-primary group-hover:translate-x-1 transition-all">→</span>
                </a></li>
                <li><a href="/contact" class="group flex items-center justify-between text-slate-600 hover:text-primary py-2 transition-colors">
                  <span>Contact opnemen</span>
                  <span class="text-stone-300 group-hover:text-primary group-hover:translate-x-1 transition-all">→</span>
                </a></li>
              </ul>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
